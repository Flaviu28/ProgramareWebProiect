<!DOCTYPE html>
<html>
<head>
  <title>Gym Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #0f172a;
      color: white;
    }

    .card {
      background: #1e293b;
      border: none;
      color: white;
    }

    a {
      text-decoration: none;
    }
  </style>
</head>

<body class="container py-5">

  <h1 class="mb-3">Welcome <%= user.email %></h1>

  <div class="alert alert-info">
    Visits in session: <strong><%= views %></strong> <br>
    Theme cookie: <strong><%= theme %></strong>
  </div>

  <h3>Workout List</h3>

  <div class="row">
    <% workouts.forEach(w => { %>
      <div class="col-md-4 mb-3">
        <div class="card p-3">
          <h5><%= w.name %></h5>
          <p><%= w.muscle %></p>

          <a class="btn btn-sm btn-primary"
             href="/gym/exercise/<%= w.id %>">
            View
          </a>
        </div>
      </div>
    <% }) %>
  </div>

  <a class="btn btn-danger mt-3" href="/logout">Logout</a>

</body>
</html>