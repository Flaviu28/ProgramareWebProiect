<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Tracker Pro - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0f172a; color: #f8fafc; min-height: 100vh; display: flex; flex-direction: column; }
        .card { background: #1e293b; border: 1px solid #334155; color: #f8fafc; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
        .text-gradient { background: linear-gradient(to right, #38bdf8, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .timer-display { font-size: 4rem; font-weight: bold; font-family: monospace; color: #38bdf8; }
        
        label, .form-label { color: #cbd5e1 !important; font-weight: 600; }
        .text-muted { color: #94a3b8 !important; }
        
        .form-control, .form-select { background-color: #0f172a !important; color: #ffffff !important; border: 1px solid #475569 !important; }
        .form-control::placeholder { color: #64748b !important; }
        .form-control:focus, .form-select:focus { border-color: #38bdf8 !important; box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.25) !important; }
        
        .nav-pills .nav-link { color: #94a3b8; }
        .nav-pills .nav-link.active { background-color: #3b82f6 !important; color: #ffffff !important; }
        footer { margin-top: auto; padding: 20px 0; }
    </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 border-bottom border-secondary">
    <div class="container">
      <a class="navbar-brand fw-bold text-gradient fs-4" href="/">Gym Tracker</a>
      <div>
        <a href="/logout" class="btn btn-danger btn-sm fw-bold">Deconectare</a>
      </div>
    </div>
  </nav>

  <div class="container flex-grow-1">
    
    <ul class="nav nav-pills mb-4 bg-dark p-2 rounded-3 border border-secondary" id="gymTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold px-4" id="workouts-tab" data-bs-toggle="tab" data-bs-target="#workouts-content" type="button" role="tab">
                Exercitii
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4" id="macros-tab" data-bs-toggle="tab" data-bs-target="#macros-content" type="button" role="tab">
                Calculator Nutritie
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4" id="timer-tab" data-bs-toggle="tab" data-bs-target="#timer-content" type="button" role="tab">
                Timer Pauza
            </button>
        </li>
    </ul>

    <div class="tab-content" id="gymTabsContent">
        
        <div class="tab-pane fade show active" id="workouts-content" role="tabpanel">
            <div class="card p-4 mb-4">
                <h5 class="mb-3 text-warning fw-bold">Adauga un exercitiu nou in jurnal</h5>
                <form action="/gym/exercise/add" method="POST" class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Nume Exercitiu</label>
                        <input type="text" name="name" class="form-control" placeholder="ex: Impins cu gantere in inclinat" required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Grupa Musculara</label>
                        <select name="muscle" class="form-select" required>
                            <option value="" disabled selected>Selecteaza grupa...</option>
                            <option value="Piept">Piept</option>
                            <option value="Spate">Spate</option>
                            <option value="Picioare">Picioare</option>
                            <option value="Brate">Brate</option>
                            <option value="Umeri">Umeri</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Adauga</button>
                    </div>
                </form>
            </div>

            <h4 class="mb-3 fw-bold text-white border-bottom border-secondary pb-2">Rutina ta de Antrenament</h4>
            <div class="row">
                <% workouts.forEach(w => { %>
                  <div class="col-md-4 mb-3">
                    <div class="card p-3 h-100 d-flex flex-column justify-content-between border-top border-primary border-3">
                      <div>
                        <h5 class="card-title fw-bold text-white mb-2"><%= w.name %></h5>
                        <span class="badge bg-primary text-white mb-3 px-2 py-1"><%= w.muscle %></span>
                      </div>
                      <a class="btn btn-sm btn-outline-info text-white w-100 fw-bold mt-2" href="/gym/exercise/<%= w.id %>">
                         Deschide Jurnalul (<%= w.logs.length %> seturi)
                      </a>
                    </div>
                  </div>
                <% }) %>
            </div>
        </div>

        <div class="tab-pane fade" id="macros-content" role="tabpanel">
            <div class="row">
                <div class="col-md-5">
                    <div class="card p-4 mb-4">
                        <h5 class="text-success mb-3 fw-bold">Calculator de Calorii si Macro</h5>
                        <form id="macroForm">
                            <div class="mb-3">
                                <label class="form-label">Greutate actuala (kg)</label>
                                <input type="number" id="weight" class="form-control" placeholder="ex: 80" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Obiectivul tau fitness</label>
                                <select id="goal" class="form-select" required>
                                    <option value="lose">Slabire / Definire musculara</option>
                                    <option value="maintain">Mentinere forma actuala</option>
                                    <option value="gain">Surplus / Masa musculara</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-success w-100 fw-bold py-2">Calculeaza Necesarul</button>
                        </form>
                    </div>
                </div>
                
                <div class="col-md-7">
                    <div class="card p-4 h-100 d-none" id="resultsCard">
                        <h5 class="text-white mb-4 fw-bold">Tintele tale nutritionale zilnice:</h5>
                        <div class="row text-center">
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-dark rounded border border-warning">
                                    <h3 class="text-warning fw-bold mb-0" id="resCal">0</h3>
                                    <small class="text-white-50">Calorii necesare</small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-dark rounded border border-danger">
                                    <h3 class="text-danger fw-bold mb-0" id="resProt">0g</h3>
                                    <small class="text-white-50">Proteine (g)</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-dark rounded border border-info">
                                    <h3 class="text-info fw-bold mb-0" id="resCarbs">0g</h3>
                                    <small class="text-white-50">Carbohidrati (g)</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-dark rounded border border-success">
                                    <h3 class="text-success fw-bold mb-0" id="resFats">0g</h3>
                                    <small class="text-white-50">Grasimi (g)</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="timer-content" role="tabpanel">
            <div class="row justify-content-center">
                <div class="col-md-6 text-center">
                    <div class="card p-5 border border-secondary" id="timerCard">
                        <h4 class="mb-4 text-info fw-bold">Cronometru Odihna intre Seturi</h4>
                        
                        <div class="timer-display my-3" id="timeLeft">01:30</div>
                        
                        <div class="d-flex justify-content-center gap-2 mb-4">
                            <button class="btn btn-sm btn-outline-light px-3" onclick="setTimer(60)">60s (Pompaj)</button>
                            <button class="btn btn-sm btn-outline-light px-3" onclick="setTimer(90)">90s (Hipertrofie)</button>
                            <button class="btn btn-sm btn-outline-light px-3" onclick="setTimer(120)">120s (Forta)</button>
                        </div>

                        <div class="d-flex justify-content-center gap-3">
                            <button class="btn btn-success px-4 fw-bold" id="startBtn" onclick="startTimer()">START</button>
                            <button class="btn btn-danger px-4 fw-bold" id="stopBtn" onclick="stopTimer()" disabled>STOP</button>
                            <button class="btn btn-warning px-4 fw-bold text-dark" onclick="resetTimer()">RESET</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
  </div>

  <footer>
    <div class="container text-center text-white-50">
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('macroForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const weight = document.getElementById('weight').value;
        const goal = document.getElementById('goal').value;

        const response = await fetch('/gym/macro/calculate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ weight, goal })
        });
        const data = await response.json();

        document.getElementById('resCal').innerText = data.calories;
        document.getElementById('resProt').innerText = data.protein + 'g';
        document.getElementById('resCarbs').innerText = data.carbs + 'g';
        document.getElementById('resFats').innerText = data.fats + 'g';
        
        document.getElementById('resultsCard').classList.remove('d-none');
    });

    let countdown;
    let totalSeconds = 90;
    let isRunning = false;

    const display = document.getElementById('timeLeft');
    const startButton = document.getElementById('startBtn');
    const stopButton = document.getElementById('stopBtn');
    const timerCard = document.getElementById('timerCard');

    function updateDisplay() {
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        display.innerText = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    }

    function setTimer(seconds) {
        if (isRunning) stopTimer();
        totalSeconds = seconds;
        timerCard.style.borderColor = '#334155';
        updateDisplay();
    }

    function startTimer() {
        if (isRunning) return;
        isRunning = true;
        startButton.disabled = true;
        stopButton.disabled = false;
        timerCard.style.borderColor = '#0dcaf0';

        countdown = setInterval(() => {
            if (totalSeconds <= 0) {
                clearInterval(countdown);
                isRunning = false;
                startButton.disabled = false;
                stopButton.disabled = true;
                timerCard.style.borderColor = '#198754';
                display.innerText = "GATA!";
                
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioCtx.createOscillator();
                oscillator.type = 'sine';
                oscillator.frequency.setValueAtTime(440, audioCtx.currentTime);
                oscillator.connect(audioCtx.destination);
                oscillator.start();
                oscillator.stop(audioCtx.currentTime + 0.3);
                return;
            }
            totalSeconds--;
            updateDisplay();
        }, 1000);
    }

    function stopTimer() {
        clearInterval(countdown);
        isRunning = false;
        startButton.disabled = false;
        stopButton.disabled = true;
        timerCard.style.borderColor = '#dc3545';
    }

    function resetTimer() {
        stopTimer();
        totalSeconds = 90;
        timerCard.style.borderColor = '#334155';
        updateDisplay();
    }
  </script>
</body>
</html>