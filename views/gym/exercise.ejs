<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Tracker Pro - Jurnal Exercitiu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0f172a; color: #f8fafc; min-height: 100vh; display: flex; flex-direction: column; }
        .card { background: #1e293b; border: 1px solid #334155; color: #f8fafc; }
        .text-gradient { background: linear-gradient(to right, #38bdf8, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        label, .form-label { color: #cbd5e1 !important; font-weight: 600; }
        .form-control { background-color: #0f172a !important; color: #ffffff !important; border: 1px solid #475569 !important; }
        .form-control::placeholder { color: #64748b !important; }
        .text-light-custom { color: #e2e8f0 !important; font-weight: 500; }
        footer { margin-top: auto; padding: 20px 0; }
    </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 border-bottom border-secondary">
    <div class="container">
      <a class="navbar-brand fw-bold text-gradient fs-4" href="/">Gym Tracker</a>
      <div>
        <a href="/logout" class="btn btn-danger btn-sm fw-bold">Deconectare</a>
      </div>
    </div>
  </nav>

  <div class="container flex-grow-1">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-white mb-1"><%= workout.name %></h2>
                    <span class="badge bg-primary fs-6"><%= workout.muscle %></span>
                </div>
                <a class="btn btn-outline-secondary btn-sm text-white" href="/gym">Inapoi la Dashboard</a>
            </div>

            <div class="row">
                <div class="col-md-5 mb-4">
                    <div class="card p-4 shadow border-start border-info border-4">
                        <h5 class="text-info mb-3 fw-bold">Adauga un set nou</h5>
                        <form action="/gym/exercise/<%= workout.id %>/log" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Greutate (kg)</label>
                                <input type="number" name="weight" class="form-control" placeholder="ex: 60" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Repetari</label>
                                <input type="number" name="reps" class="form-control" placeholder="ex: 10" required>
                            </div>
                            <button class="btn btn-info w-100 fw-bold text-white">Salveaza Setul</button>
                        </form>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="card p-4 shadow">
                        <h5 class="mb-3 text-white-50 fw-bold">Istoric performante</h5>
                        <% if(workout.logs.length === 0) { %>
                            <p class="text-muted mb-0">Nu ai salvat niciun set inca pentru acest exercitiu.</p>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-dark table-striped m-0 text-center align-middle">
                                    <thead>
                                        <tr>
                                            <th>Data</th>
                                            <th>Greutate</th>
                                            <th>Repetari</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% workout.logs.forEach(log => { %>
                                            <tr>
                                                <td class="text-light-custom"><%= log.date %></td>
                                                <td class="fw-bold text-warning"><%= log.weight %> kg</td>
                                                <td class="text-info"><%= log.reps %> Reps</td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </div>

  <footer>
    <div class="container text-center text-white-50">
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>